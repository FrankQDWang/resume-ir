{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "resume-ir",
  "version": "0.1.1",
  "identifier": "local.resume-ir.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "resume-ir", "width": 1320, "height": 820, "minWidth": 720, "minHeight": 560 }],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; style-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": { "active": false, "icon": [] }
}
