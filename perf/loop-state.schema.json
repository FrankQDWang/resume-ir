{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/resume-ir/perf/loop-state.schema.json",
  "title": "resume-ir long-running goal loop state report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "goal_id",
    "workflow_state",
    "experiment_state",
    "evidence_lane",
    "contract_pins",
    "allowed_paths",
    "verification",
    "privacy"
  ],
  "properties": {
    "schema_version": { "const": "resume-ir.loop-state-report.v2" },
    "goal_id": { "const": "resume-ir.performance-gui-loop.2026-06" },
    "workflow_state": {
      "enum": [
        "intake",
        "ceo_reviewed",
        "plan_ready",
        "plan_reviewed",
        "slice_active",
        "red_check_written",
        "implementation_active",
        "verification_active",
        "evidence_review",
        "slice_complete",
        "blocked",
        "goal_complete",
        "goal_authorized",
        "baseline_captured",
        "discovery_profile_issue_opened",
        "hypothesis_recorded",
        "slice_selected",
        "branch_active",
        "pr_opened",
        "base_synced",
        "pr_review_ready",
        "ci_green",
        "local_gate_green",
        "privacy_gate_green",
        "merge_method_selected",
        "pr_merged",
        "issue_reconciled_with_evidence",
        "next_issue_or_goal_complete",
        "blocked_needs_external_input",
        "blocked_external_retryable",
        "blocked_permission",
        "contract_conflict",
        "goal_unsatisfiable",
        "budget_exhausted",
        "aborted_by_policy",
        "contract_invalid"
      ]
    },
    "experiment_state": {
      "enum": [
        "not_started",
        "contract_locked",
        "baseline_validated",
        "profile_captured",
        "bottleneck_selected",
        "hypothesis_registered",
        "optimization_slice_active",
        "correctness_passed",
        "perf_measured",
        "reprofiled",
        "cross_os_passed",
        "accepted",
        "reverted",
        "blocked",
        "complete"
      ]
    },
    "evidence_lane": {
      "enum": ["smoke", "w0_docs", "w1_private", "soak_fault", "gui_manual"]
    },
    "optimization_layer": { "$ref": "#/$defs/optimization_layer" },
    "affected_layers": {
      "type": "array",
      "items": { "$ref": "#/$defs/optimization_layer" },
      "uniqueItems": true
    },
    "platform_lane": { "$ref": "#/$defs/platform_lane" },
    "visual_reference": { "$ref": "#/$defs/visual_reference" },
    "layer_closure": { "$ref": "#/$defs/layer_closure" },
    "run_id": { "type": "string", "minLength": 1 },
    "state_version": { "type": "integer", "minimum": 0 },
    "previous_state_hash": { "$ref": "#/$defs/hex64" },
    "lease_owner": { "type": "string", "minLength": 1 },
    "lease_expires_at": { "type": "string", "minLength": 1 },
    "heartbeat_at": { "type": "string", "minLength": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "expected_state_version": { "type": "integer", "minimum": 0 },
    "last_confirmed_side_effect": { "type": "string", "minLength": 1 },
    "next_wake_at": { "type": "string", "minLength": 1 },
    "goal_prompt": { "$ref": "#/$defs/goal_prompt" },
    "event_log": { "$ref": "#/$defs/event_log" },
    "runtime_capability_attestation": { "$ref": "#/$defs/runtime_capability_attestation" },
    "runner_recovery": { "$ref": "#/$defs/runner_recovery" },
    "transition_graph": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition_rule" }
    },
    "contract_pins": { "$ref": "#/$defs/contract_pins" },
    "contract_integrity": { "$ref": "#/$defs/contract_integrity" },
    "github_ledger": { "$ref": "#/$defs/github_ledger" },
    "retry_policy": { "$ref": "#/$defs/retry_policy" },
    "allowed_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "current_slice": { "type": "string" },
    "blocked_count": { "type": "integer", "minimum": 0 },
    "same_blocker_key": { "type": "string" },
    "transition_history": {
      "type": "array",
      "items": { "$ref": "#/$defs/transition" }
    },
    "hypothesis": { "$ref": "#/$defs/hypothesis" },
    "accepted_cells": {
      "description": "Legacy derived snapshot for older loop reports. Completion authority is evidence_cells.",
      "type": "array",
      "items": {
        "enum": [
          "w0_docs",
          "d10k_private_calibration",
          "d100k_weak_host",
          "d1m_scale",
          "soak_fault",
          "gui_manual"
        ]
      },
      "uniqueItems": true
    },
    "evidence_cells": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_cell" },
      "uniqueItems": true
    },
    "verification": { "$ref": "#/$defs/verification" },
    "privacy": { "$ref": "#/$defs/privacy" }
  },
  "allOf": [
    {
      "if": { "properties": { "workflow_state": { "const": "goal_complete" } }, "required": ["workflow_state"] },
      "then": {
        "required": ["evidence_cells", "transition_history"],
        "properties": {
          "experiment_state": { "const": "complete" },
          "verification": {
            "type": "object",
            "required": ["commands", "all_required_commands_ran", "claim"],
            "properties": {
              "commands": { "minItems": 1 },
              "all_required_commands_ran": { "const": true },
              "claim": { "const": "pass" }
            }
          },
          "evidence_cells": {
            "allOf": [
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "w0_docs" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "d10k_private_calibration" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "d100k_weak_host" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "d1m_scale" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "soak_fault" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "gui_manual" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "first_searchable" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "full_import_ocr_backlog" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "query_hot_path" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "agent_query_replay" } } } },
              { "contains": { "type": "object", "required": ["cell"], "properties": { "cell": { "const": "repeat_amplification_control" } } } }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "experiment_state": { "const": "hypothesis_registered" } }, "required": ["experiment_state"] },
      "then": { "required": ["hypothesis"] }
    },
    {
      "if": {
        "properties": {
          "experiment_state": {
            "enum": [
              "optimization_slice_active",
              "correctness_passed",
              "perf_measured",
              "reprofiled"
            ]
          }
        },
        "required": ["experiment_state"]
      },
      "then": { "required": ["hypothesis"] }
    },
    {
      "if": {
        "properties": {
          "experiment_state": { "enum": ["accepted", "reverted", "complete"] }
        },
        "required": ["experiment_state"]
      },
      "then": {
        "required": ["hypothesis"],
        "properties": {
          "hypothesis": {
            "type": "object",
            "required": [
              "expected_effect",
              "before_measurement_ref",
              "after_measurement_ref",
              "reprofile_ref",
              "decision"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "hex64": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "git_head": { "type": "string", "pattern": "^([a-f0-9]{7,40}|working-tree)$" },
    "terminal_state": {
      "enum": [
        "goal_complete",
        "blocked_external_retryable",
        "blocked_permission",
        "contract_conflict",
        "goal_unsatisfiable",
        "budget_exhausted",
        "aborted_by_policy",
        "contract_invalid"
      ]
    },
    "goal_prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version",
        "max_chars",
        "compiler",
        "compiler_implemented_in_current_pr",
        "deterministic_serialization_required",
        "fail_on_over_budget",
        "silent_truncation_allowed",
        "untrusted_external_text_is_data",
        "one_transition_per_wake"
      ],
      "properties": {
        "format_version": { "const": 1 },
        "max_chars": { "const": 4000 },
        "compiler": { "const": "scripts/loop/compile-goal-prompt.py" },
        "compiler_implemented_in_current_pr": { "const": false },
        "deterministic_serialization_required": { "const": true },
        "field_priority_required": { "const": true },
        "character_budget_required": { "const": true },
        "state_version_required": { "const": true },
        "state_hash_required": { "const": true },
        "policy_hash_required": { "const": true },
        "prompt_hash_required": { "const": true },
        "fail_on_over_budget": { "const": true },
        "silent_truncation_allowed": { "const": false },
        "untrusted_external_text_is_data": { "const": true },
        "one_transition_per_wake": { "const": true },
        "historical_details_in_prompt_allowed": { "const": false },
        "minimal_next_transition_only": { "const": true }
      }
    },
    "event_log": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for_runner_implementation",
        "append_only",
        "events_path_template",
        "derived_current_state_only",
        "direct_current_state_edit_allowed",
        "previous_event_hash_required",
        "idempotency_key_required",
        "intent_before_side_effect_required",
        "verify_after_side_effect_required",
        "compare_and_swap_state_update_required",
        "lease_required",
        "heartbeat_required"
      ],
      "properties": {
        "required_for_runner_implementation": { "const": true },
        "append_only": { "const": true },
        "events_path_template": { "const": "perf/runs/<run_id>/events/<state_version>.json" },
        "derived_current_state_only": { "const": true },
        "direct_current_state_edit_allowed": { "const": false },
        "previous_event_hash_required": { "const": true },
        "idempotency_key_required": { "const": true },
        "intent_before_side_effect_required": { "const": true },
        "verify_after_side_effect_required": { "const": true },
        "compare_and_swap_state_update_required": { "const": true },
        "lease_required": { "const": true },
        "heartbeat_required": { "const": true }
      }
    },
    "runtime_capability_attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "permissions_are_policy_not_capability",
        "observe_before_act",
        "record_unavailable_capability",
        "missing_capability_terminal_states",
        "required_capabilities"
      ],
      "properties": {
        "required": { "const": true },
        "permissions_are_policy_not_capability": { "const": true },
        "observe_before_act": { "const": true },
        "record_unavailable_capability": { "const": true },
        "missing_capability_terminal_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/terminal_state" },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "runner_recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lease_required",
        "heartbeat_required",
        "cas_required",
        "idempotency_key_required",
        "intent_before_side_effect_required",
        "verify_after_side_effect_required",
        "one_transition_per_wake",
        "capability_attestation_required"
      ],
      "properties": {
        "lease_required": { "const": true },
        "heartbeat_required": { "const": true },
        "cas_required": { "const": true },
        "idempotency_key_required": { "const": true },
        "intent_before_side_effect_required": { "const": true },
        "verify_after_side_effect_required": { "const": true },
        "one_transition_per_wake": { "const": true },
        "capability_attestation_required": { "const": true }
      }
    },
    "transition_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "from", "to", "required_permissions", "required_evidence", "allowed_actions"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "from": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        },
        "to": { "type": "string", "minLength": 1 },
        "required_permissions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "required_evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "allowed_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "contract_pins": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_goal_sha256",
        "acceptance_matrix_sha256",
        "loop_state_schema_sha256",
        "experiment_report_schema_sha256",
        "git_head_sha"
      ],
      "properties": {
        "active_goal_sha256": { "$ref": "#/$defs/hex64" },
        "acceptance_matrix_sha256": { "$ref": "#/$defs/hex64" },
        "loop_state_schema_sha256": { "$ref": "#/$defs/hex64" },
        "experiment_report_schema_sha256": { "$ref": "#/$defs/hex64" },
        "git_head_sha": { "$ref": "#/$defs/git_head" }
      }
    },
    "contract_integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_contract_hash",
        "acceptance_matrix_hash",
        "runner_version",
        "benchmark_runner_version"
      ],
      "properties": {
        "goal_contract_hash": { "$ref": "#/$defs/hex64" },
        "acceptance_matrix_hash": { "$ref": "#/$defs/hex64" },
        "runner_version": { "type": "string", "minLength": 1 },
        "benchmark_runner_version": { "type": "string", "minLength": 1 }
      }
    },
    "github_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_issue", "active_prs", "open_blockers"],
      "properties": {
        "primary_issue": { "type": "string", "pattern": "^#[0-9]+$" },
        "active_prs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^#[0-9]+$" },
          "uniqueItems": true
        },
        "open_blockers": {
          "type": "array",
          "items": { "type": "string", "pattern": "^#[0-9]+$" },
          "uniqueItems": true
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker_key", "same_condition_count", "attempts"],
      "properties": {
        "blocker_key": { "type": "string", "minLength": 1 },
        "same_condition_count": { "type": "integer", "minimum": 0, "maximum": 3 },
        "attempts": {
          "type": "array",
          "items": { "$ref": "#/$defs/retry_attempt" }
        }
      }
    },
    "retry_attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt_id", "evidence_path", "action", "result"],
      "properties": {
        "attempt_id": { "type": "string", "minLength": 1 },
        "evidence_path": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "result": { "enum": ["passed", "failed", "blocked"] }
      }
    },
    "evidence_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cell",
        "goal_contract_hash",
        "acceptance_matrix_hash",
        "runner_version",
        "benchmark_runner_version",
        "main_reachable_commit"
      ],
      "properties": {
        "cell": {
          "enum": [
            "w0_docs",
            "d10k_private_calibration",
            "d100k_weak_host",
            "d1m_scale",
            "soak_fault",
            "gui_manual",
            "first_searchable",
            "full_import_ocr_backlog",
            "query_hot_path",
            "agent_query_replay",
            "repeat_amplification_control"
          ]
        },
        "goal_contract_hash": { "$ref": "#/$defs/hex64" },
        "acceptance_matrix_hash": { "$ref": "#/$defs/hex64" },
        "runner_version": { "type": "string", "minLength": 1 },
        "benchmark_runner_version": { "type": "string", "minLength": 1 },
        "query_set_sha256": { "$ref": "#/$defs/hex64" },
        "corpus_profile_hash": { "$ref": "#/$defs/hex64" },
        "benchmark_report_hash": { "$ref": "#/$defs/hex64" },
        "benchmark_artifact_id": { "type": "string", "minLength": 1 },
        "main_reachable_commit": { "$ref": "#/$defs/git_head" }
      },
      "anyOf": [
        { "required": ["benchmark_report_hash"] },
        { "required": ["benchmark_artifact_id"] }
      ]
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "evidence_ref"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "evidence_ref": { "type": "string", "minLength": 1 }
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "acceptance_cell", "expected_effect", "before_measurement_ref"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "acceptance_cell": { "type": "string", "minLength": 1 },
        "expected_effect": { "type": "string", "minLength": 1 },
        "baseline_noise_band_pct": { "type": "number", "minimum": 0 },
        "before_measurement_ref": { "type": "string", "minLength": 1 },
        "after_measurement_ref": { "type": "string", "minLength": 1 },
        "reprofile_ref": { "type": "string", "minLength": 1 },
        "decision": { "enum": ["accepted", "reverted", "blocked"] }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands", "all_required_commands_ran", "claim"],
      "properties": {
        "commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/command_result" }
        },
        "all_required_commands_ran": { "type": "boolean" },
        "claim": { "enum": ["pass", "fail", "blocked", "partial"] }
      }
    },
    "command_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "exit_code", "evidence_ref"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "exit_code": { "type": "integer" },
        "evidence_ref": { "type": "string", "minLength": 1 }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contains_raw_resume_text",
        "contains_raw_query_text",
        "contains_candidate_results",
        "contains_local_paths",
        "contains_tokens",
        "contains_diagnostics_package"
      ],
      "properties": {
        "contains_raw_resume_text": { "const": false },
        "contains_raw_query_text": { "const": false },
        "contains_candidate_results": { "const": false },
        "contains_local_paths": { "const": false },
        "contains_tokens": { "const": false },
        "contains_diagnostics_package": { "const": false }
      }
    },
    "optimization_layer": { "enum": ["L1", "L2", "L3", "L4"] },
    "platform_lane": { "enum": ["macos_m4_discovery", "windows_weak_host_validation", "cross_os_ci_smoke"] },
    "visual_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference_role", "default_stack", "production_next_server_allowed"],
      "properties": {
        "reference_role": { "const": "visual_baseline_not_functional_clone" },
        "default_stack": { "const": "tauri_react_vite_tailwind_typescript" },
        "visual_reference_path": { "const": "UI-reference/" },
        "production_next_server_allowed": { "const": false },
        "pixel_level_visual_similarity_required": { "const": true }
      }
    },
    "layer_closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_blocker_layer", "closing_layer", "lower_layer_closes_higher_layer_blocker"],
      "properties": {
        "primary_blocker_layer": { "$ref": "#/$defs/optimization_layer" },
        "closing_layer": { "$ref": "#/$defs/optimization_layer" },
        "lower_layer_closes_higher_layer_blocker": { "const": false }
      }
    }
  }
}
